{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Server Supervisor",
  "version": "0.1.25",
  "identifier": "com.sirbepy.server-supervisor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:6970",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Server Supervisor",
        "width": 440,
        "height": 580,
        "minWidth": 440,
        "minHeight": 380,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "publisher": "SirBepy"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SirBepy/server_supervisor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDMkUwQjcwMDg3MzA2MUEKUldRYUJuTUljQXN1dk5QWDdCYmxvRjc0Y0dVODVmTTdKWGNuT2ErdWlSSCtZdkdQaTFzdk5GNXgK",
      "dialog": false
    }
  }
}
